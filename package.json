{
  "name": "medium-clone",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build:shared": "pnpm --filter @repo/shared build",
    "dev:shared": "pnpm --filter @repo/shared dev",
    "dev": "pnpm build:shared && concurrently -k -n api,web -c blue,green \"pnpm --filter @repo/api dev\" \"pnpm --filter @repo/web dev\"",
    "dev:api": "pnpm build:shared && pnpm --filter @repo/api dev",
    "dev:web": "pnpm build:shared && pnpm --filter @repo/web dev",
    "build": "pnpm build:shared && pnpm --filter @repo/api build && pnpm --filter @repo/web build",
    "lint": "pnpm --filter @repo/api --filter @repo/web --parallel lint",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f",
    "db:generate": "pnpm --filter @repo/api prisma:generate",
    "db:migrate": "pnpm --filter @repo/api prisma:migrate",
    "db:seed": "pnpm --filter @repo/api prisma:seed",
    "db:reset": "pnpm --filter @repo/api prisma:reset",
    "prod:up": "docker compose -f docker-compose.prod.yml up --build -d",
    "prod:down": "docker compose -f docker-compose.prod.yml down",
    "prod:logs": "docker compose -f docker-compose.prod.yml logs -f"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "typescript": "^5.9.2"
  }
}
