# ---- Postgres (docker-compose) ----
POSTGRES_USER=medium
POSTGRES_PASSWORD=medium
POSTGRES_DB=medium

# ---- API (apps/api) ----
# host -> ต่อ postgres/redis ที่ localhost (local dev; host port 5433/6380 เลี่ยงชนพอร์ต)
# ใน prod compose จะ override เป็น service name (postgres:5432 / redis:6379)
DATABASE_URL=postgresql://medium:medium@localhost:5433/medium?schema=public
REDIS_URL=redis://localhost:6380
# ต้องตั้งค่าเอง (ยาว >= 16 ตัวอักษร) — สร้างด้วย: openssl rand -base64 48
JWT_SECRET=please_generate_a_strong_secret
JWT_EXPIRES_IN=7d
API_PORT=3005
CORS_ORIGIN=http://localhost:3006

# ---- Web (apps/web) ----
# เว็บเรียก API ผ่าน Kong gateway
NEXT_PUBLIC_API_URL=http://localhost:8000/api
